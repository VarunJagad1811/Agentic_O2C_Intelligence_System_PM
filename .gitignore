faiss_index/
*.faiss
*.index
*.csv
*.xlsx
*.pkl
*.h5
*.joblib

# --- Python & Cache (Prevents Merge Conflicts) ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# --- Virtual Environments (Massive folders, never push) ---
.venv/
venv/
env/

# --- IDE & OS Junk ---
.vscode/
.idea/
.DS_Store
Thumbs.db